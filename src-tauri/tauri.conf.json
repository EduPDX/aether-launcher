{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aether Launcher",
  "version": "0.2.1",
  "identifier": "com.aether.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aether Launcher",
        "width": 1000,
        "height": 780,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/EduPDX/aether-launcher/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5MzU2NDRENDA2QzE5MEUKUldRT0dXeEFUV1ExU1lPTWVvZTdXYktqWmpSeUF6d0c0Y0VLS2x0Qm52M0xBR3RSMVBIbisvOFUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Aether Platform",
    "copyright": "© 2026 Aether Platform",
    "category": "Game",
    "shortDescription": "Launcher do Aether para servidores de jogos",
    "longDescription": "Sincroniza mods, instala Java e Forge e abre o Minecraft já conectado ao servidor. Software de código aberto do projeto Aether Platform.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
